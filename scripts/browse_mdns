#!/usr/bin/env python3
# ruff: noqa: T201
"""Browse the local network for ADAM Audio speakers via mDNS.

Listens for _oca._udp.local. service advertisements and prints the
service name, server hostname, addresses, port, and TXT properties
for each device found. Useful for debugging zeroconf discovery issues.

Usage:
    python scripts/browse_mdns
"""

from __future__ import annotations

import time

from zeroconf import ServiceBrowser, ServiceStateChange, Zeroconf

SERVICE_TYPE = "_oca._udp.local."


def on_service_state_change(
    zeroconf: Zeroconf,
    service_type: str,
    name: str,
    state_change: ServiceStateChange,
) -> None:
    """Print details when a service is added or removed."""
    info = zeroconf.get_service_info(service_type, name)
    labels = {
        ServiceStateChange.Added: "FOUND",
        ServiceStateChange.Removed: "LOST",
        ServiceStateChange.Updated: "UPDATED",
    }
    label = labels.get(state_change, state_change.name.upper())

    print(f"\n{'=' * 60}")
    print(f"  [{label}] {name}")
    if info:
        print(f"  Server     : {info.server}")
        print(f"  Addresses  : {info.parsed_addresses()}")
        print(f"  Port       : {info.port}")
        props = {k.decode(): v.decode() for k, v in info.properties.items()}
        print(f"  Properties : {props}")
    else:
        print("  (no additional info)")
    print(f"{'=' * 60}")


if __name__ == "__main__":
    zc = Zeroconf()
    print(f"Browsing for {SERVICE_TYPE} services... (Ctrl+C to stop)\n")
    ServiceBrowser(zc, SERVICE_TYPE, handlers=[on_service_state_change])
    try:
        while True:
            time.sleep(0.5)
    except KeyboardInterrupt:
        print("\nStopped.")
    finally:
        zc.close()
