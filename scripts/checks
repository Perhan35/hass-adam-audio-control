#!/usr/bin/env bash
# Pre-push CI check — mirrors the GitHub Actions test.yml pipeline.
# Run this before committing to catch issues locally.

set -e

cd "$(dirname "$0")/.."

echo "=== Ruff lint ==="
ruff check --fix .

echo "=== Ruff format ==="
ruff format .

scripts/tests lib
scripts/tests integration

echo ""
echo "All checks passed!"
