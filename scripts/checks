#!/usr/bin/env bash
# Pre-push CI check — mirrors the GitHub Actions test.yml pipeline.
# Run this before committing to catch issues locally.

set -e

cd "$(dirname "$0")/.."

echo "=== Ruff lint ==="
ruff check --fix .

echo "=== Ruff format ==="
ruff format .

echo "=== Tests + coverage ==="
pytest tests/ -v --cov=custom_components.adam_audio --cov-fail-under=95

echo ""
echo "All checks passed!"
