#!/usr/bin/env bash
# Pre-push CI check — mirrors the GitHub Actions test.yml pipeline.
# Run this before committing to catch issues locally.

set -e

cd "$(dirname "$0")/.."

echo "=== Ruff lint ==="
ruff check --fix .

echo "=== Ruff format ==="
ruff format .

scripts/tests lib
scripts/tests integration

# Validate against HA Core ruff & mypy rules if ha-core is available
HA_CORE="${HA_CORE_PATH:-$(cd .. && pwd)/ha-core}"
if [ -d "$HA_CORE/homeassistant/components/adam_audio" ]; then
    echo ""
    echo "=== Core validation (ruff + mypy) ==="
    scripts/validate_core "$HA_CORE"
fi

echo ""
echo "All checks passed!"
